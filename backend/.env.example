# Local: Docker replica set OR Windows Mongo with replSetName rs0 — see README.md
# If "docker" is not recognized: use MongoDB Atlas (free) or Option C in README (local repl set).
# If port 27017 is already used by another MongoDB, stop that service before docker compose.
DATABASE_URL="mongodb://127.0.0.1:27017/poc_management?replicaSet=rs0&directConnection=true"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRY=7d
BCRYPT_ROUNDS=12
JWT_REFRESH_TTL_SECONDS=1209600
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
GEMINI_API_KEY=your_api_key_here
GEMINI_DOCUMENTATION_MODEL=gemini-2.5-flash
